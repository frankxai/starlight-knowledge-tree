{
  "name": "@starlight/graph-utils",
  "version": "0.1.0",
  "description": "Graph traversal and validation utilities for Starlight Knowledge Tree",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "validate-graph": "./dist/cli/validate.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "validate": "npm run build && node dist/cli/validate.js",
    "validate:fiction": "npm run build && node dist/cli/validate-fiction.js",
    "test": "npm run build && node --test test/*.test.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@starlight/graph-schema": "0.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
