{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://starlightintelligence.org/knowledge-tree/schemas/edge.schema.json",
  "title": "KnowledgeTreeEdge",
  "description": "A directed edge between two nodes in the Starlight Knowledge Tree graph",
  "type": "object",
  "required": ["type", "target"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "requires",
        "unlocks",
        "applies_to",
        "evidenced_by",
        "contributes_to",
        "contradicts",
        "updated_by",
        "part_of",
        "teaches",
        "tests"
      ]
    },
    "target": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Target node ID"
    },
    "weight": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Optional confidence or strength of the edge (0.0–1.0)"
    },
    "note": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional human-readable annotation"
    },
    "deprecated": {
      "type": "boolean",
      "description": "Mark as true if this edge is no longer valid but preserved for history"
    }
  },
  "additionalProperties": false
}
